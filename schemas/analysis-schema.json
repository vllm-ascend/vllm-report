{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily Commit Analysis",
  "description": "AI analysis result for a single day's commits",
  "type": "object",
  "required": ["date", "repo", "generated_at", "daily_summary", "commits"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date in UTC+8 (YYYY-MM-DD)"
    },
    "repo": {
      "type": "string",
      "pattern": "^.+/.+$",
      "description": "GitHub repo full name (owner/repo)"
    },
    "generated_at": {
      "type": "string",
      "description": "Timestamp when analysis was generated (ISO 8601 with timezone)"
    },
    "daily_summary": {
      "type": "string",
      "description": "Summary of the day's changes"
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sha", "comment", "tags", "test_impact"],
        "properties": {
          "sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$",
            "description": "Full commit SHA"
          },
          "comment": {
            "type": "string",
            "description": "AI analysis comment for this commit"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Classification tags (type, risk, module)"
          },
          "test_impact": {
            "type": "object",
            "required": ["needs_new_test", "reason", "suggested_test_areas"],
            "properties": {
              "needs_new_test": {
                "type": "boolean",
                "description": "Whether new test cases are needed"
              },
              "reason": {
                "type": "string",
                "description": "Reason for the assessment"
              },
              "suggested_test_areas": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Suggested files or modules for new tests"
              }
            }
          },
          "ascend_impact": {
            "type": ["object", "null"],
            "description": "Impact on vllm-ascend project (only for vllm repo)",
            "properties": {
              "ascend_affected": {
                "type": "boolean",
                "description": "Whether this commit affects vllm-ascend"
              },
              "functionality": {
                "type": "string",
                "description": "Functional impact on vllm-ascend"
              },
              "testing": {
                "type": "string",
                "description": "Testing impact on vllm-ascend"
              }
            }
          }
        }
      }
    }
  }
}
