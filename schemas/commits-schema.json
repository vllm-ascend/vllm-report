{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily Commits Data",
  "description": "Commit data for a single day",
  "type": "object",
  "required": ["date", "repo", "branch", "commits"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "repo": {
      "type": "string",
      "pattern": "^.+/.+$"
    },
    "branch": {
      "type": "string"
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sha", "author", "date", "message", "parents"],
        "properties": {
          "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "author": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string" }
            }
          },
          "date": { "type": "string" },
          "message": { "type": "string" },
          "parents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stats": {
            "type": "object",
            "properties": {
              "total_additions": { "type": "integer" },
              "total_deletions": { "type": "integer" },
              "files_changed": { "type": "integer" }
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "filename": { "type": "string" },
                "status": { "type": "string" },
                "additions": { "type": "integer" },
                "deletions": { "type": "integer" },
                "patch": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
